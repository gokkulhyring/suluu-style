{
  "name": "suluu-clone",
  "version": "1.0.0",
  "description": "Suluu Style Beauty Salon - Website Clone",
  "scripts": {
    "tw:build": "tailwindcss -i ./src/tailwind.css -o ./public/css/tailwind.css",
    "tw:watch": "tailwindcss -i ./src/tailwind.css -o ./public/css/tailwind.css --watch",
    "build": "npm run tw:build && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/serve-static": "^4.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "swiper": "^12.1.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@tailwindcss/cli": "^4.2.2",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "autoprefixer": "^10.4.27",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.1.3"
  }
}
